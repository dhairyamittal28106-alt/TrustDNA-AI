      "post": {
        "operationId": "create_identity_genome_api_v1_identity_genomes_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateIdentityGenomeRequest"
              }
            }
          },
          "required": true
