{
  "components": {
    "schemas": {
      "ArtifactType": {
        "enum": [
          "email",
          "document",
          "resume",
          "voice",
          "image",
          "certificate"
        ],
        "title": "ArtifactType",
        "type": "string"
      },
      "CertificateResponse": {
        "properties": {
          "certificate_number": {
            "title": "Certificate Number",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "identity_confidence": {
            "title": "Identity Confidence",
            "type": "number"
          },
          "identity_genome_id": {
            "format": "uuid",
            "title": "Identity Genome Id",
            "type": "string"
          },
          "issued_at": {
            "format": "date-time",
            "title": "Issued At",
            "type": "string"
          },
          "trust_rating": {
            "title": "Trust Rating",
            "type": "string"
          }
        },
        "required": [
          "id",
          "certificate_number",
          "identity_genome_id",
          "identity_confidence",
          "trust_rating",
          "issued_at"
        ],
        "title": "CertificateResponse",
        "type": "object"
      },
      "CreateIdentityGenomeRequest": {
        "additionalProperties": false,
        "properties": {
          "display_name": {
            "maxLength": 120,
            "minLength": 1,
            "title": "Display Name",
            "type": "string"
          },
          "owner_id": {
            "format": "uuid",
            "title": "Owner Id",
            "type": "string"
          }
        },
        "required": [
          "owner_id",
          "display_name"
        ],
        "title": "CreateIdentityGenomeRequest",
        "type": "object"
      },
      "CreateInvestigationRequest": {
        "additionalProperties": false,
        "properties": {
          "artifact_reference": {
            "maxLength": 500,
            "minLength": 1,
            "title": "Artifact Reference",
            "type": "string"
          },
          "artifact_type": {
            "$ref": "#/components/schemas/ArtifactType"
          },
          "identity_genome_id": {
            "format": "uuid",
            "title": "Identity Genome Id",
            "type": "string"
          }
        },
        "required": [
          "identity_genome_id",
          "artifact_type",
          "artifact_reference"
        ],
        "title": "CreateInvestigationRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "IdentityGenomeResponse": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "display_name": {
            "title": "Display Name",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "owner_id": {
            "format": "uuid",
            "title": "Owner Id",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          }
        },
        "required": [
          "id",
          "owner_id",
          "display_name",
          "created_at",
          "updated_at"
        ],
        "title": "IdentityGenomeResponse",
        "type": "object"
      },
      "InvestigationResponse": {
        "properties": {
          "artifact_reference": {
            "title": "Artifact Reference",
            "type": "string"
          },
          "artifact_type": {
            "$ref": "#/components/schemas/ArtifactType"
          },
          "case_number": {
            "title": "Case Number",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "identity_genome_id": {
            "format": "uuid",
            "title": "Identity Genome Id",
            "type": "string"
          },
          "opened_at": {
            "format": "date-time",
            "title": "Opened At",
            "type": "string"
          },
          "risk_level": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RiskLevel"
              },
              {
                "type": "null"
              }
            ]
          },
          "status": {
            "$ref": "#/components/schemas/InvestigationStatus"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          },
          "verdict": {
            "$ref": "#/components/schemas/Verdict"
          }
        },
        "required": [
          "id",
          "case_number",
          "identity_genome_id",
          "artifact_type",
          "artifact_reference",
          "status",
          "verdict",
          "risk_level",
          "opened_at",
          "updated_at"
        ],
        "title": "InvestigationResponse",
        "type": "object"
      },
      "InvestigationStatus": {
        "enum": [
          "queued",
          "investigating",
          "completed",
          "failed"
        ],
        "title": "InvestigationStatus",
        "type": "string"
      },
      "RiskLevel": {
        "enum": [
          "low",
          "medium",
          "high",
          "critical"
        ],
        "title": "RiskLevel",
        "type": "string"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "Verdict": {
        "enum": [
          "pending",
          "authentic",
          "inconclusive",
          "impersonation_confirmed"
        ],
        "title": "Verdict",
        "type": "string"
      }
    }
  },
  "info": {
    "title": "TrustDNA API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/certificates/{certificate_id}": {
      "get": {
        "operationId": "get_certificate_api_v1_certificates__certificate_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "certificate_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Certificate Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CertificateResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Certificate",
        "tags": [
          "Certificates"
        ]
      }
    },
