              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Identity Genome",
        "tags": [
          "Identity Genome"
        ]
      }
    },
    "/api/v1/identity-genomes/{genome_id}": {
      "get": {
        "operationId": "get_identity_genome_api_v1_identity_genomes__genome_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "genome_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Genome Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IdentityGenomeResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Identity Genome",
        "tags": [
          "Identity Genome"
        ]
      }
    },
    "/api/v1/investigations": {
      "post": {
        "operationId": "open_investigation_api_v1_investigations_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInvestigationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvestigationResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Open Investigation",
        "tags": [
