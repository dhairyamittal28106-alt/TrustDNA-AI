{
  "components": {
    "schemas": {
      "AgentName": {
        "enum": [
          "genesis",
          "cipher",
          "chronos",
          "forensiq",
          "spectra",
          "atlas"
        ],
        "title": "AgentName",
        "type": "string"
      },
      "AgentResult": {
        "additionalProperties": false,
        "description": "The only result format permitted from a forensic agent.",
        "properties": {
          "agent": {
            "$ref": "#/components/schemas/AgentName"
          },
          "confidence": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "type": "number"
          },
          "evidence": {
            "items": {
              "$ref": "#/components/schemas/EvidenceItem"
            },
            "title": "Evidence",
            "type": "array"
          },
          "findings": {
            "items": {
              "$ref": "#/components/schemas/Finding"
            },
            "title": "Findings",
            "type": "array"
          },
          "limitations": {
            "items": {
              "type": "string"
            },
            "title": "Limitations",
            "type": "array"
          },
          "processing_time_ms": {
            "minimum": 0.0,
            "title": "Processing Time Ms",
            "type": "integer"
          },
          "version": {
            "pattern": "^v\\d+(\\.\\d+){0,2}$",
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "agent",
          "confidence",
          "processing_time_ms",
          "version"
        ],
        "title": "AgentResult",
        "type": "object"
      },
      "ArtifactType": {
        "enum": [
          "plain_text",
          "email",
          "document",
          "resume",
          "voice",
          "image",
          "certificate"
        ],
        "title": "ArtifactType",
        "type": "string"
      },
      "CaseLifecycleState": {
        "enum": [
          "case_created",
          "collecting_evidence",
          "dispatching_agents",
          "awaiting_results",
          "aggregating",
          "risk_analysis",
          "generating_findings",
          "generating_certificate",
          "closed"
        ],
        "title": "CaseLifecycleState",
        "type": "string"
      },
      "CertificateResponse": {
